<html>
  <meta charset="utf-8"/>
  <meta name=”apple-mobile-web-app-capable” content=”yes “>
  
  <head>
    <link rel="stylesheet" href="jiggle.css">
    <link rel="stylesheet" href="index.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
  </head>
  
  <body>
    <div class=title>பாடல்: ஜீவ சரடு வாத்தியத்தில்: ராரவேணு கோபாலா</div>
    <div class=subtitle>
      ராகம்: பிலஹரி, தாளம்: ஆதி<br>
      பக்க வாத்தியம்: <a href=https://play.google.com/store/apps/details?id=com.rajaramaniyer.jalra>ராஜாராமன் ஐயர் (Jalra/Android)</a><br>
      நன்றி <a href=https://www.youtube.com/watch?v=IDEst-udTfo>ராம் சுந்தர்</a>,&nbsp;  
                 <a href=https://www.youtube.com/watch?v=USq45E48GGc>நவநீத் சுந்தர்</a>

      <div style="text-align:center;">
        <button id=btn onclick="start()">ॐ</button>
      </div>
    </div>

    <!-- pN will be unhidden at N * 1.5s from start time -->
    <div id=main>

      <span id=p0 class="hidden svara">சா ரி கா பா - </span>
      <span id=p2 class="hidden svara">தா சா நீ தா</span>                  <br>
      <span id=p4 class="hidden svara">பா த ப ம க ரி ச - </span>
      <span id=p6 class="hidden svara">ரி ச நி த சா</span>                 <br>
      <span id=p8 class=hidden>ரார வேணு</span>
      <span id=p10 class=hidden>கோ- -பாலா</span>                         <br>
      <span id=p12 class=hidden>ராஜித சத்குண</span>
      <span id=p14 class=hidden>ஜெயசீலா</span>                            <br><br>
      <!-- -->

      <span id=p16 class="hidden svara">சா ரி கா பா - </span>
      <span id=p18 class="hidden svara">மா க பா தா</span>                 <br>
      <span id=p20 class="hidden svara">ரீ ச நீ தா - </span>
      <span id=p22 class="hidden svara">பா ம கா ரீ</span>                  <br>
      <span id=p24 class=hidden>சார சாக்ஷா</span>
      <span id=p26 class=hidden>நேரமேமி</span>                            <br>
      <span id=p28 class=hidden>மாரு பாதா</span>
      <span id=p30 class=hidden>கோர்வலேரா</span>                         <br>
      <span id=p32 class=hidden>(ரார வேணு...)</span>                     <br><br> <!-- 8 -->
      <!-- -->

      <span id=p40 class="hidden svara">சா ரி கா கா கா - ரி க பா ப பா பா பா - த ப சா ச சா சா</span>   <br> <!-- 10 -->
      <span id=p50 class="hidden svara">க ரி ச நி நி த பா - </span>
      <span id=p52 class="hidden svara">ப த ப ம க ரி ரீ</span>                                         <br>
      <span id=p54 class="hidden svara">க ப ம க ரி ச ரி க</span>                                      <br>
      <span id=p56 class=hidden>நந்தகோபாலா - நீ நெந்து போஜாலா - நீ விந்து ராரா</span>                       <br> <!-- 10 -->
      <span id=p66 class=hidden>சதமல மதிலோ </span>
      <span id=p68 class=hidden>முதமல ரகனா</span>                                                    <br>
      <span id=p70 class=hidden>கெதுருக கதியர</span><br>
      <span id=p72 class=hidden>(ராரவேணு... சாரசாக்ஷா... ராரவேணு...)</span>                           <br><br> <!-- 24 -->
      <!-- 2 -->

      <span id=p98 class="hidden svara">ப ப பா - ரி ரி ரீ - </span>
      <span id=p100 class="hidden svara">க ப ம க கா</span><br>
      <span id=p102 class="hidden svara">க ப ம க ம க ரி ச - </span>
      <span id=p104 class="hidden svara"> ரி க ரி ச சா </span>                         <br>
      <span id=p106 class="hidden svara">ரி ச நி த சா</span>                            <br>
      <span id=p108 class="hidden svara">ம க ரி க பா</span>                            <br>
      <span id=p110 class="hidden svara">த ப த ரி சா</span>                           <br>
      <span id=p112 class="hidden svara">ரி ச நி த ப ம க ரி </span>                    <br>
      <span id=p114 class="hidden svara">(ராரவேணு...)</span>                          <br><br> <!-- 8 -->

      <span id=p122 class=hidden>பலுமாருனுகா-</span>
      <span id=p124 class=hidden>-ரவமுனனின்</span><br>
      <span id=p126 class=hidden>பிலிசின பலுகவு-</span>
      <span id=p128 class=hidden>-னலுககுரா</span><br>
      <span id=p130 class=hidden>கரிவரதா</span> <br>
      <span id=p132 class=hidden>மரிமரினா</span><br>
      <span id=p134 class=hidden>யதரமுக்ரோ</span><br>
      <span id=p136 class=hidden>லரகனிகரமுக</span> <br>
      <span id=p138 class=hidden>(ராரவேணு... சாரசாக்ஷா... ராரவேணு...)</span> <!-- 24 --><br><br>
      <!-- 2 -->

      <span id=p164 class="hidden svara">பா ம க ரி க - </span>
      <span id=p166 class="hidden svara">தா ம க ரி க - </span>
      <span id=p168 class="hidden svara">பா ம க ரி க - </span>
      <span id=p170 class="hidden svara">பா பா பா</span>                                      <br>
      <span id=p172 class="hidden svara">கா ரி ச நி த - </span>
      <span id=p174 class="hidden svara">ரீ ரி ச நி த - </span>
      <span id=p176 class="hidden svara">சா ரி ச நி த -</span>
      <span id=p178 class="hidden svara">சா சா சா</span>                                       <br>
      <span id=p180 class="hidden svara">கா ரி ச ரீ ரீ ரீ - ரீ ச நி தா தா தா - பா ம க கா கா கா</span> <!-- 9 --> <br>
      <span id=p189 class="hidden svara">ச ரி க த பா - ரி ச ரி க சா</span>        <!-- 4 -->          <br>
      <span id=p193 class="hidden svara">க ரி ச நி த ப ம க ரி ச ரி க</span>          <!-- 3 -->         <br>
      <span id=p196 class="hidden svara">(ரார வேணு...)</span>              <!-- 8 -->         <br><br>

      <span id=p204 class=hidden>ரா நகதர</span>
      <span id=p206 class=hidden>ரா முரஹர</span>
      <span id=p208 class=hidden>ரா பவஹர</span>
      <span id=p210 class=hidden>ராவேரா</span>                                        <br>
      <span id=p212 class=hidden>ஈ மகுவனு</span>
      <span id=p214 class=hidden>ஈ லலலனு</span>
      <span id=p216 class=hidden>ஈ சொகசினி</span>
      <span id=p218 class=hidden>சேகோரா</span>                                       <br>
      <span id=p220 class=hidden>கோரிக லிம்பொந்தா - டெந்தமு நீயந்தா - சேரெனு நின்செந்தா</span> <!-- 9 --> <br>
      <span id=p229 class=hidden>மருவகு ரா - கரமுல சே</span>        <!-- 4 -->          <br>
      <span id=p233 class=hidden>மரிமரி நினு சரணனிதர</span>          <!-- 3 -->         <br>
      <span id=p236 class=hidden>(ராரவேணு... சாரசாக்ஷா... ராரவேணு...)</span> <!-- 24 --><br><br>
      <!-- -->

    </div>
    <script src=raravenu.js></script>
  </body>
</html>
